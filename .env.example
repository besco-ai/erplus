# ═══════════════════════════════════
#  ERPlus — Variáveis de Ambiente
# ═══════════════════════════════════
# Copie para .env e preencha os valores

# ── PostgreSQL ──
DB_HOST=db
DB_PORT=5432
DB_NAME=erplus
DB_USER=erplus
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# ── JWT ──
JWT_SECRET_KEY=CHANGE_ME_MINIMUM_32_CHARACTERS_LONG_SECRET_KEY
JWT_ISSUER=ERPlus
JWT_AUDIENCE=ERPlus

# ── Client ──
CLIENT_URL=https://erplus.egconsultorias.com.br

# ── ASP.NET ──
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
