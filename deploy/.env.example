# ═══════════════════════════════════════════════════════════════════
#  ERPlus — Production environment variables
# ═══════════════════════════════════════════════════════════════════
#
# O arquivo real .env vive na VPS, em /opt/erplus/.env, e NUNCA vai pro
# git. Os valores reais são gerados aleatoriamente pelo bootstrap.sh.

# ── Domínio servido + email de contato para Let's Encrypt ──
DOMAIN=erplus.besco.ai
LETSENCRYPT_EMAIL=admin@besco.ai

# ── PostgreSQL ──
POSTGRES_DB=erplus
POSTGRES_USER=erplus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ──
# Trocar por string aleatória com pelo menos 64 caracteres em produção
JWT_SECRET_KEY=CHANGE_ME_64_CHARS_MINIMUM_RANDOM_STRING
JWT_ISSUER=ERPlus
JWT_AUDIENCE=ERPlus

# ── URL pública do frontend (usada pelo CORS do backend) ──
CLIENT_URL=https://erplus.besco.ai

# ── ASP.NET Core ──
ASPNETCORE_ENVIRONMENT=Production
